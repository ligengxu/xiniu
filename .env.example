# ╔═══════════════════════════════════════════════════════╗
# ║          犀牛 Agent 配置模板 / Xiniu Agent Config     ║
# ║   复制此文件为 .env.local 并填入你的 API Key           ║
# ║   Copy to .env.local and fill in your API keys       ║
# ╚═══════════════════════════════════════════════════════╝

# ─── AI 模型 (至少配置一个 / Configure at least one) ───

# OpenAI (或兼容 API / or compatible API)
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek
DEEPSEEK_API_KEY=

# 通义千问 Qwen (国内推荐 / Recommended for China)
QWEN_API_KEY=

# OpenRouter (多模型聚合 / Multi-model gateway)
OPENROUTER_API_KEY=

# ─── 可选服务 (Optional Services) ───

# Stability AI (图片生成 / Image generation)
# STABILITY_API_KEY=

# DashScope (通义万相文生图 / Tongyi image gen)
# DASHSCOPE_API_KEY=

# ─── 技能商店源 (Skill Store Source) ───
# 默认从 GitHub 下载，可改为自建源
# Default: GitHub. Can point to self-hosted source.
# XINIU_SKILL_SOURCE=https://raw.githubusercontent.com/ligengxu/xiniu/community-skills/src/skills/community

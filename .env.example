# ═══════════════════════════════════════════════════
# 犀牛 Agent 环境变量配置
# 复制此文件为 .env.local 并填入你的 API Key
# cp .env.example .env.local
# ═══════════════════════════════════════════════════

# ─── AI 模型 API Key（至少配置一个）───

# OpenAI GPT-4o / GPT-4o-mini
OPENAI_API_KEY=

# DeepSeek Chat / Reasoner
DEEPSEEK_API_KEY=

# 通义千问 Qwen Plus / Turbo（国内推荐，无需翻墙）
QWEN_API_KEY=

# OpenRouter（聚合多家模型）
OPENROUTER_API_KEY=

# ─── 搜索技能模型配置（可选）───

# 搜索技能使用的 AI 提供商和模型（默认 qwen/qwen-turbo）
# SEARCH_PROVIDER_ID=qwen
# SEARCH_MODEL_ID=qwen-turbo

# ─── 图片生成（可选）───

# 通义万相
# DASHSCOPE_API_KEY=

# Stability AI
# STABILITY_API_KEY=

# ─── 邮件发送（可选，smart_email 技能）───

# SMTP_HOST=smtp.example.com
# SMTP_PORT=465
# SMTP_USER=
# SMTP_PASS=
